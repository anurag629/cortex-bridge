{
  "name": "@anurag629/opencode-cognee",
  "version": "0.1.0",
  "description": "Persistent memory for OpenCode, backed by Cognee. Auto-captures agent activity, recalls across sessions, survives compaction, and learns from feedback.",
  "type": "module",
  "license": "MIT",
  "author": "anurag629",
  "keywords": ["opencode", "opencode-plugin", "cognee", "memory", "agent", "ai"],
  "engines": {
    "opencode": ">=1.17.0"
  },
  "bin": {
    "opencode-cognee": "./dist/install.js"
  },
  "exports": {
    ".": "./dist/cognee.plugin.js",
    "./server": "./dist/cognee.plugin.js"
  },
  "files": ["dist", "README.md", ".env.example"],
  "scripts": {
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "bun run scripts/smoke.ts",
    "link": "bun run dist/install.js",
    "prepublishOnly": "bun run build.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}

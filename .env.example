# Cognee connection for the OpenCode memory plugin.
# All settings are optional; sensible defaults target a local self-hosted server.

# local (self-hosted, username/password) or cloud (hosted instance, API key).
# Mode is just a label now; auth is chosen by which credentials you set below.
COGNEE_MODE=local

# Base URL of the Cognee server. Local: http://localhost:8000.
# Cloud / hosted instance: https://your-instance.cognee.ai
COGNEE_BASE_URL=http://localhost:8000

# API path prefix. Both local and hosted Cognee serve under /api/v1.
# Only override (e.g. to "") if a gateway in front of your instance strips it.
COGNEE_API_PREFIX=/api/v1

# Local auth: only needed if the server runs with access control on.
# For fastest local dev, boot Cognee with ENABLE_BACKEND_ACCESS_CONTROL=False
# and REQUIRE_AUTHENTICATION=False, then leave these unset.
# COGNEE_USERNAME=default_user@example.com
# COGNEE_PASSWORD=changeme

# Cloud auth: required when COGNEE_MODE=cloud
# COGNEE_API_KEY=your_cognee_cloud_api_key

# Override the per-project dataset name (default: oc-mem-<project>)
# COGNEE_DATASET=oc-mem-myrepo

# How many memory items to pull on recall
COGNEE_TOP_K=8

# Debounce window (ms) before bridging a session's cache into the graph
COGNEE_BRIDGE_DEBOUNCE_MS=120000

# Capture tool output text into trace entries (true/false)
COGNEE_CAPTURE_TOOL_OUTPUT=true

# Per-request timeout (ms). Captures/bridge use this.
COGNEE_REQUEST_TIMEOUT_MS=30000

# Recall timeout (ms). Recall is on the chat critical path, so keep it tight.
COGNEE_RECALL_TIMEOUT_MS=10000

# Verbose plugin logging to stderr
COGNEE_DEBUG=false

# Cortex Bridge connection settings, read by the OpenCode adapter and every
# other adapter. All optional; defaults target a local self-hosted Cognee server.
# CORTEX_* is canonical; the legacy COGNEE_* names still work as a fallback.

# local (self-hosted, username/password) or cloud (hosted instance, API key).
# Mode is just a label; auth is chosen by which credentials you set below.
CORTEX_MODE=local

# Base URL of the Cognee server. Local: http://localhost:8000.
# Cloud / hosted instance: https://your-instance.cognee.ai
CORTEX_BASE_URL=http://localhost:8000

# API path prefix. Both local and hosted Cognee serve under /api/v1.
# Only override (e.g. to "") if a gateway in front of your instance strips it.
CORTEX_API_PREFIX=/api/v1

# Local auth: only needed if the server runs with access control on.
# For fastest local dev, boot Cognee with ENABLE_BACKEND_ACCESS_CONTROL=False
# and REQUIRE_AUTHENTICATION=False, then leave these unset.
# CORTEX_USERNAME=default_user@example.com
# CORTEX_PASSWORD=changeme

# Cloud auth: required when CORTEX_MODE=cloud
# CORTEX_API_KEY=your_cognee_cloud_api_key

# Shared dataset name. Pin the SAME value across every agent to share memory.
# Default is a per-project name (cortex-<project>).
# CORTEX_DATASET=team-mesh

# How many memory items to pull on recall
CORTEX_TOP_K=8

# Debounce window (ms) before bridging a session's cache into the graph
CORTEX_BRIDGE_DEBOUNCE_MS=120000

# Capture tool output text into trace entries (true/false)
CORTEX_CAPTURE_TOOL_OUTPUT=true

# Per-request timeout (ms). Captures/bridge use this.
CORTEX_REQUEST_TIMEOUT_MS=30000

# Recall timeout (ms). Recall is on the chat critical path, so keep it tight.
CORTEX_RECALL_TIMEOUT_MS=10000

# Verbose adapter logging to stderr
CORTEX_DEBUG=false
